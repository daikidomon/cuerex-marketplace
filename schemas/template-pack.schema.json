{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketplace.cuerex.ai/schemas/template-pack.schema.json",
  "title": "cuerex Template Pack",
  "type": "object",
  "required": ["kind", "version", "name", "templates"],
  "additionalProperties": true,
  "properties": {
    "kind": {
      "const": "cuerex.templatePack"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "compatibleWith": {
      "type": "object"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "prompt"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
